{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "TrackFish",
  "description": "Guia de uso de TrackFish — control de produccion, logistica y finanzas para frigorificos de pescado.",
  "colors": { "primary": "#0D9488", "light": "#14B8A6", "dark": "#0F766E" },
  "favicon": "/favicon.ico",
  "icons": { "library": "lucide" },
  "styling": { "eyebrows": "breadcrumbs" },
  "contextual": { "options": ["copy", "view", "assistant"] },
  "navigation": {
    "global": {
      "anchors": [
        { "anchor": "TrackFish.io", "icon": "house", "href": "https://www.trackfish.io/" },
        { "anchor": "Soporte", "icon": "life-buoy", "href": "mailto:soporte@trackfish.io" }
      ]
    },
    "groups": [
      {
        "group": "Primeros pasos", "icon": "rocket",
        "pages": ["empezando/bienvenida","empezando/conceptos-clave","empezando/primer-acceso","empezando/planes"]
      },
      {
        "group": "Produccion", "icon": "package",
        "pages": ["produccion/lotes","produccion/cajas-y-qr","produccion/capturas","produccion/especies"]
      },
      {
        "group": "Logistica", "icon": "truck",
        "pages": ["logistica/depositos","logistica/cargas","logistica/entregas-directas","logistica/camiones"]
      },
      {
        "group": "Clientes y Ventas", "icon": "users",
        "pages": ["clientes/gestion-clientes","clientes/precios","clientes/reservas","ventas/ventas","ventas/pagos-y-cobros"]
      },
      {
        "group": "Finanzas", "icon": "wallet",
        "pages": ["finanzas/gastos","finanzas/proveedores"]
      },
      {
        "group": "Equipo", "icon": "users-round",
        "pages": ["equipo/usuarios-y-roles"]
      },
      {
        "group": "Configuracion", "icon": "settings",
        "pages": ["configuracion/empresa","configuracion/notificaciones","configuracion/suscripcion"]
      }
    ]
  },
  "logo": { "light": "/logo/light.svg", "dark": "/logo/dark.svg" },
  "navbar": {
    "links": [],
    "primary": { "type": "button", "label": "Ir a TrackFish", "href": "https://www.trackfish.io/" }
  },
  "footer": {
    "socials": { "x": "https://x.com/trackfishio", "linkedin": "https://linkedin.com/company/trackfish" }
  }
}
